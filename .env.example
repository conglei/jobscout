# joblode-server config. Copy to `.env` (gitignored) and fill in keys.
# Real environment variables take precedence over this file.

# Dataset path (default: open-jobs.parquet, relative to the working dir).
# JOBLODE_PARQUET=/absolute/path/to/open-jobs.parquet

# HTTP bind address (loopback only). Default 127.0.0.1:8000.
# JOBLODE_HTTP_ADDR=127.0.0.1:8000

# --- Ranking: match / pairwise (optional; free taste ranking works without it) ---
# JOBLODE_RANK_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-key
# JOBLODE_RANK_MATCH_MODEL=gemini-2.5-flash
# JOBLODE_RANK_PAIR_MODEL=gemini-2.5-flash-lite
# JOBLODE_RANK_BASE_URL=

# --- Semantic search (optional) ---
# Must embed queries in the dataset's space (text-embedding-3-small, 1536-d).
# JOBLODE_EMBED_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key
# JOBLODE_EMBED_MODEL=text-embedding-3-small
# JOBLODE_EMBED_BASE_URL=
